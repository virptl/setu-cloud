# setu-cloud environment configuration
# Copy to .env and fill in real values before running.

# ── Server ───────────────────────────────────────────────────────────────────
LISTEN_ADDR=:8080

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://setu:setu_pass@localhost:5432/setucore?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_byte_random_hex

# ── MQTT (connection from setu-cloud → EMQX) ─────────────────────────────────
MQTT_BROKER_URL=mqtts://192.168.4.1:8883
MQTT_CLIENT_ID=setu-cloud
MQTT_USERNAME=setucloud
MQTT_PASSWORD=replace_with_emqx_password
# Path to the EMQX CA certificate PEM file (for TLS verification)
MQTT_CA_CERT_FILE=/etc/setu/emqx-ca.pem

# ── Device MQTT URI (sent to devices during provisioning) ─────────────────────
# This is the broker URI the device will use after shipping.
# Dev: Pi5 hotspot. Prod: your public VPS.
DEVICE_MQTT_BROKER_URI=mqtts://192.168.4.1:8883

# ── Factory ZTP ──────────────────────────────────────────────────────────────
# Must match CONFIG_SETU_FACTORY_PROV_TOKEN in firmware sdkconfig.
# Leave empty to disable token enforcement.
FACTORY_PROV_TOKEN=

# Tenant ES256 public key (128 lowercase hex chars = 64 bytes).
# This is the key baked into firmware as CLOUD_SERVER_PUB_KEY_DEFAULT.
# Run tools/gen_keypair to generate a new pair.
CLOUD_PUBKEY_HEX=ab67d99e340956...1cda
